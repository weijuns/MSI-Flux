[Dynamic, Provider("WmiProv"),
 guid("{BD2A216F-2FB9-a640-B807-DDDBAD656891}"),
 Locale("MS\0x409"),
 Description("CPU")]
class MSI_CPU {
    [key, read] string InstanceName;
