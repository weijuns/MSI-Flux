// MSI WMI ACPI schema for GPU switching
// Register with: mofcomp MSI_ACPI.mof
// This schema is normally installed by Feature Manager / MSI Center.
// Without it, the MSI_ACPI and Package_32 WMI classes don't exist in root\wmi.

#pragma AUTORECOVER
#pragma namespace ("\\\\.\\root\\wmi")

// Package data types (same GUID family ABBC0F6x)

[Dynamic, Provider("WmiProv"),
 guid("{ABBC0F60-8EA1-11d1-00A0-C90629100000}"),
 Locale("MS\0x409"),
 Description("This class contains the definition of the package used in other classes")]
class Package {
    [WmiDataId(1), write, read, Description("16 bytes of data")]
    uint8 Bytes[16];
};

[Dynamic, Provider("WmiProv"),
 guid("{ABBC0F61-8EA1-11d1-00A0-C90629100000}"),
 Locale("MS\0x409"),
 Description("This class contains the definition of the package used in other classes")]
class Package_1 {
    [WmiDataId(1), write, read, Description("1 bytes of data")]
    uint8 Bytes[1];
};

[Dynamic, Provider("WmiProv"),
 guid("{ABBC0F62-8EA1-11d1-00A0-C90629100000}"),
 Locale("MS\0x409"),
 Description("This class contains the definition of the package used in other classes")]
class Package_10 {
    [WmiDataId(1), write, read, Description("10 bytes of data")]
    uint8 Bytes[10];
};

[Dynamic, Provider("WmiProv"),
 guid("{ABBC0F63-8EA1-11d1-00A0-C90629100000}"),
 Locale("MS\0x409"),
 Description("This class contains the definition of the package used in other classes")]
class Package_32 {
    [WmiDataId(1), write, read, Description("32 bytes of data")]
    uint8 Bytes[32];
};

// MSI data block classes

[Dynamic, Provider("WmiProv"),
 guid("{5B3CC38A-40D9-7245-8AE6-1145B751BE3F}"),
 Locale("MS\0x409"),
 Description("Event defined by MSI")]
class MSI_Event {
    [key, read] string InstanceName;
    [read] boolean Active;
    [WmiDataId(1), write, read, Description("Event defined by MSI")] uint32 MSIEvt;
};

[Dynamic, Provider("WmiProv"),
 guid("{24418D6A-0A79-524C-9AB1-18B78CA68CE7}"),
 Locale("MS\0x409"),
 Description("Software")]
