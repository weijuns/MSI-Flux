// Main ACPI method class

[Dynamic, Provider("WmiProv"),
 guid("{ABBC0F6E-8EA1-11d1-00A0-C90629100000}"),
 Locale("MS\0x409"),
 Description("Class used to operate methods on a package")]
class MSI_ACPI {
    [key, read]
    string InstanceName;

    [read]
    boolean Active;

    [Implemented, WmiMethodId(1)]
    void GetPackage([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(2)]
    void SetPackage([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(3)]
    void Get_EC([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(4)]
    void Set_EC([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(5)]
    void Get_BIOS([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(6)]
    void Set_BIOS([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(7)]
    void Get_SMBUS([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(8)]
    void Set_SMBUS([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(9)]
    void Get_MasterBattery([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(10)]
    void Set_MasterBattery([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(11)]
    void Get_SlaveBattery([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(12)]
    void Set_SlaveBattery([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(13)]
    void Get_Temperature([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(14)]
    void Set_Temperature([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(15)]
    void Get_Thermal([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(16)]
    void Set_Thermal([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(17)]
    void Get_Fan([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(18)]
    void Set_Fan([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(19)]
    void Get_Device([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(20)]
    void Set_Device([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(21)]
    void Get_Power([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(22)]
    void Set_Power([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(23)]
    void Get_Debug([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(24)]
    void Set_Debug([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(25)]
    void Get_AP([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(26)]
    void Set_AP([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(27)]
    void Get_Data([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(28)]
    void Set_Data([in, out] Package_32 ref Data);

    [Implemented, WmiMethodId(29)]
    void Get_WMI([in, out] Package_32 ref Data);
};
