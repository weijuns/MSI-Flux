[Dynamic, Provider("WmiProv"),
 guid("{1EC3EC7A-1E9B-e74a-9026-CF122B0BBD21}"),
 Locale("MS\0x409"),
 Description("VGA")]
class MSI_VGA {
    [key, read] string InstanceName;
    [read] boolean Active;
    [WmiDataId(1), write, read, Description("VGA")] uint8 VGA;
