[Dynamic, Provider("WmiProv"),
 guid("{2D3CBA6C-1C9C-7f41-B54C-F5D5D580D482}"),
 Locale("MS\0x409"),
 Description("Power")]
class MSI_Power {
    [key, read] string InstanceName;
    [read] boolean Active;
    [WmiDataId(1), write, read, Description("Power")] uint8 Power;
};

[Dynamic, Provider("WmiProv"),
 guid("{40BA026D-075D-cd4a-9710-F7C57347CAC9}"),
 Locale("MS\0x409"),
 Description("Master_Battery")]
class MSI_Master_Battery {
    [key, read] string InstanceName;
    [read] boolean Active;
    [WmiDataId(1), write, read, Description("Master_Battery")] sint16 Master_Battery;
};

[Dynamic, Provider("WmiProv"),
 guid("{8DBCCF6E-9DB4-0e46-A3F2-99AFAAA77A7A}"),
 Locale("MS\0x409"),
 Description("Slave_Battery")]
class MSI_Slave_Battery {
    [key, read] string InstanceName;
    [read] boolean Active;
    [WmiDataId(1), write, read, Description("Slave_Battery")] sint16 Slave_Battery;
